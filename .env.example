# ── AI APIs ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Printify ─────────────────────────────────────────────────────────────────
# Generate at: https://printify.com/app/account/connections
PRINTIFY_API_KEY=
# Found at: https://printify.com/app/account/connections → your shop row
PRINTIFY_SHOP_ID=

# ── Etsy API v3 ───────────────────────────────────────────────────────────────
# Create an app at: https://www.etsy.com/developers/register
ETSY_API_KEY=
ETSY_SHARED_SECRET=
# OAuth 2.0 access token — obtain via the Etsy OAuth flow:
#   https://developers.etsy.com/documentation/essentials/authentication
ETSY_ACCESS_TOKEN=

# ── Loop config ───────────────────────────────────────────────────────────────
# How many hours to wait between scouting cycles (default: 6)
LOOP_INTERVAL_HOURS=6
